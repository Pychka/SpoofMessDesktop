<UserControl x:Class="SpoofMess.ViewElements.InputTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpoofMess.ViewElements"
             mc:Ignorable="d" x:Name="InputTextBoxView">
    <Grid>
        <TextBox Background="White" Text="{Binding ElementName=InputTextBoxView, Path=Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextChanged="InputTextChanged" x:Name="Input"/>
        <TextBlock VerticalAlignment="Center" Margin="5 0 0 0" FontSize="20" Foreground="Gray" Background="Transparent" x:Name="HolderText" IsHitTestVisible="False" Text="{Binding ElementName=InputTextBoxView, Path=Holder}"/>
    </Grid>
</UserControl>
