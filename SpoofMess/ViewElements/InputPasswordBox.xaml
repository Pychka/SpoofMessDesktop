<UserControl x:Class="SpoofMess.ViewElements.InputPasswordBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpoofMess.ViewElements"
             mc:Ignorable="d" 
            d:DesignHeight="50" d:DesignWidth="200" x:Name="InputPasswordBoxView">
    <Grid>
        <TextBlock Background="White" x:Name="HolderText" Text="{Binding ElementName=InputPasswordBoxView, Path=Holder}"/>
        <TextBox Background="Transparent" Text="{Binding ElementName=InputPasswordBoxView, Path=Text}" TextChanged="InputTextChanged" x:Name="Input"/>
    </Grid>
</UserControl>
