<UserControl x:Class="SpoofMess.ViewElements.InputPasswordBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpoofMess.ViewElements"
             mc:Ignorable="d" x:Name="InputPasswordBoxView">
    <ContentControl x:Name="Field" Loaded="Field_Loaded">
        <ContentControl.Template>
            <ControlTemplate>
                <Border Padding="0" x:Name="border" BorderThickness="1" Background="{DynamicResource SecondWhite}" CornerRadius="{DynamicResource Corner2}">
                    <Grid ColumnDefinitions="* auto">
                        <TextBlock 
                            VerticalAlignment="Center" 
                            Foreground="Gray" 
                            Style="{StaticResource PlaceHolder}" 
                            x:Name="HolderText" 
                            Margin="0"
                            IsHitTestVisible="False" 
                            Panel.ZIndex="1"
                            Text="{Binding ElementName=InputPasswordBoxView, Path=Holder}"
                            Background="Transparent"/>
                        <TextBox
                            BorderBrush="Transparent"
                            Height="auto"
                            Margin="0"
                            VerticalScrollBarVisibility="Auto" 
                            TextChanged="InputTextChanged" 
                            x:Name="Input" 
                            Style="{DynamicResource PasswordBox}"/>
                        <ToggleButton 
                            Click="ToggleButton_Click"
                            Grid.Column="1" 
                            Visibility="{Binding
                                ElementName=InputPasswordBoxView, 
                                Path=WithShowing}">
                            <ToggleButton.Style>
                                <Style BasedOn="{StaticResource MinimalToggleButton}" TargetType="{x:Type ToggleButton}">
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Content" Value="🙈"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter Property="Content" Value="🙉"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                    </Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource PrimaryAccent}"/>
                        <Setter Property="Background" TargetName="border" Value="{StaticResource PrimaryWhite}"/>
                    </Trigger>

                    <Trigger SourceName="Input" Property="IsKeyboardFocused" Value="True">
                        <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource SecondAccent}"/>
                        <Setter Property="Background" TargetName="border" Value="{StaticResource ThirdWhite}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </ContentControl.Template>
    </ContentControl>
</UserControl>
