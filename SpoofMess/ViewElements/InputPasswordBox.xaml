<UserControl x:Class="SpoofMess.ViewElements.InputPasswordBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpoofMess.ViewElements"
             mc:Ignorable="d" x:Name="InputPasswordBoxView">
    <Grid>
        <TextBox Background="White" Text="{Binding ElementName=InputPasswordBoxView, Path=Text}" TextChanged="InputTextChanged" x:Name="Input"/>
        <TextBlock Background="Transparent" IsHitTestVisible="False"  x:Name="HolderText" Text="{Binding ElementName=InputPasswordBoxView, Path=Holder}"/>
    </Grid>
</UserControl>
