<Window x:Class="SpoofMess.Views.EntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpoofMess.Views"
        xmlns:uc="clr-namespace:SpoofMess.ViewElements"
        xmlns:vm="clr-namespace:SpoofMess.ViewModels"
        mc:Ignorable="d"
        Title="EntryWindow" Height="450" Width="800">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
        <uc:InputTextBox Holder="Логин" Text="{Binding Model.Login}"/>
        <uc:InputTextBox Holder="Пароль" Text="{Binding Model.Password}"/>
        <Button Content="Вход" Command="{Binding EntryCommand}" Style="{DynamicResource RightFunctionButton}" IsDefault="True"/>
    </StackPanel>
</Window>
