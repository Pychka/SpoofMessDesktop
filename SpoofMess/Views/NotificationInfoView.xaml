<UserControl x:Class="SpoofMess.Views.NotificationInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpoofMess.Views"
             xmlns:data="clr-namespace:SpoofMess.Models.API"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance data:Notification, IsDesignTimeCreatable=False}" Opacity="{Binding Opacity}">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border CornerRadius="10" Background="{DynamicResource ThirdWhite}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="#999999" ShadowDepth="0" RenderingBias="Quality"/>
            </Border.Effect>
        </Border>
        <Border CornerRadius="10" Background="White" Padding="10 20">
            <TextBlock Text="{Binding Text}"/>
        </Border>
    </Grid>
</UserControl>
